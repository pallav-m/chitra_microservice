# Copy to .env and adjust. All values are optional — these are the defaults.
# Variable names are the Settings field names (case-insensitive).

# Inference device: "cuda", "mps", or "cpu". Leave empty (or "auto") to
# auto-detect the best available backend (cuda > mps > cpu).
DEVICE=

# Demucs pretrained model name (e.g. htdemucs, htdemucs_ft).
DEMUCS_MODEL=htdemucs

# Reject inputs longer than this (seconds) before they reach the GPU.
MAX_AUDIO_DURATION_SEC=600

# 0 = keep model-native rate (44.1 kHz) and channel layout. Non-zero downmixes
# each output stem to mono and resamples to this rate (e.g. 16000 for ASR).
OUTPUT_SAMPLE_RATE=0

# audioUri download limits.
DOWNLOAD_TIMEOUT_SEC=30
MAX_DOWNLOAD_BYTES=104857600

# --- GPU concurrency (per-instance) ---
# Hard cap on concurrent GPU work per model. Size so the worst-case simultaneous
# mix fits the GPU's VRAM (measure with scripts/measure_vram.py).
DEMUCS_MAX_CONCURRENCY=4
SPEAKER_MAX_CONCURRENCY=8
# Optional aggregate ceiling across all models (0 = disabled).
GPU_MAX_CONCURRENCY=0
# How long a request waits for a free slot before getting 503 + Retry-After.
GPU_ACQUIRE_TIMEOUT_SEC=30
